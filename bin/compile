#!/usr/bin/env bash

set -e # fail fast

# Exclusion patterns ("!" lines) behave like .gitignore globs:
#   *      - matches anything except a slash
#   **     - matches across directory boundaries (recursive)
#   ?, []  - standard shell globbing
# nullglob: patterns that match nothing expand to nothing (instead of the literal pattern)
# dotglob: globs also match dot files (like .gitignore does)
#
# Additive entries are NOT globbed: they are taken as literal file or folder
# paths and copied as a whole. This avoids looping over individual files and
# keeps caching fast even for very large directory trees.
shopt -s nullglob dotglob globstar


indent() {
  sed -u 's/^/       /'
}


BUILD_DIR=$1
CACHE_DIR=$2
HOME_FOLDER_REPLACEMENT="__CACHE_HOME__"


echo "=====> Caching files for future builds"


# Start from a clean cache each build. Without this, files that are no longer
# matched by .buildcache (because they were removed from the source or from the
# .buildcache file) would linger in the cache forever, making it grow without
# bound across builds.
rm -rf "${CACHE_DIR}/buildcache"


while IFS= read -r LINE || [ -n "${LINE}" ]; do
  # normalize line endings and surrounding whitespace
  LINE="${LINE%$'\r'}"
  LINE="$(echo "${LINE}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"

  # skip blank lines and comments
  [ -z "${LINE}" ] && continue
  case "${LINE}" in
    \#*) continue ;;
  esac

  # a leading "!" negates the pattern, removing matches from the cache set
  NEGATE=false
  case "${LINE}" in
    !*)
      NEGATE=true
      LINE="${LINE#!}"
      ;;
    \\!* | \\#*)
      # allow escaping a literal leading "!" or "#"
      LINE="${LINE#\\}"
      ;;
  esac

  # determine the base directory the pattern is resolved against
  if [[ ${LINE} = \~/* ]]; then
    BASE="${HOME}"
    CACHE_BASE="${CACHE_DIR}/buildcache/${HOME_FOLDER_REPLACEMENT}"
    SUB="${LINE#\~/}"
  else
    BASE="${BUILD_DIR}"
    CACHE_BASE="${CACHE_DIR}/buildcache"
    SUB="${LINE}"
  fi

  if ${NEGATE}; then
    # Exclusions support globbing. They only affect entries that were added by
    # lines above, because those are the only files copied into the cache so
    # far at this point.
    for MATCH in ${CACHE_BASE}/${SUB}; do
      REL="${MATCH#"${CACHE_BASE}"/}"
      echo -n "${REL}" | indent
      rm -rf "${MATCH}"
      echo " ✗ - excluded"
    done
    continue
  fi

  # Additive entry: a literal file or folder path, copied as a whole.
  SRC="${BASE}/${SUB}"
  DEST="${CACHE_BASE}/${SUB}"

  echo -n "${SUB}" | indent

  # skip non-existing files
  if ! [ -e "${SRC}" ]; then
    echo " ✗ - not found"
    continue
  fi

  # create parent directory structure
  mkdir -p "$(dirname "${DEST}")"

  # delete old files
  if [ -e "${DEST}" ]; then
    rm -r "${DEST}"
  fi

  # copy files to cache
  cp -r "${SRC}" "${DEST}"

  echo " ✓"
done < "${BUILD_DIR}/.buildcache"
